{
  "name": "@doodledood/manifest-dev-pi",
  "version": "0.11.4",
  "private": true,
  "description": "Pi package surface for manifest-dev shared skills and Harness-level Do runtime entrypoints (/do, /auto, /babysit-pr).",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "pi-package",
    "manifest-dev",
    "agent-skills"
  ],
  "exports": {
    "./extension": "./pi/extensions/manifest-dev.ts",
    "./runtime": "./pi/extensions/manifest-dev-runtime.ts"
  },
  "pi": {
    "extensions": [
      "./pi/extensions/manifest-dev.ts",
      "./packages/manifest-dev-pi-tools/pi/extensions/manifest-dev-tools.ts"
    ],
    "skills": [
      "./dist/pi/skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  }
}
