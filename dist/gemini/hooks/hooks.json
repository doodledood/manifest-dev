{
  "hooks": {
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/stop_do_hook.py",
            "name": "stop-do",
            "timeout": 10000,
            "description": "Enforces /do workflow completion before stopping"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/post_compact_hook.py",
            "name": "post-compact",
            "timeout": 10000,
            "description": "Restores /do context after session resume/compact"
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/post_compact_hook.py",
            "name": "pre-compress-recovery",
            "timeout": 10000,
            "description": "Restores /do context after compaction"
          }
        ]
      }
    ]
  }
}
