{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "activate_skill",
        "sequential": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/pretool_verify_hook.py",
            "name": "pretool-verify",
            "timeout": 10000,
            "description": "Reminds model to read manifest before running /verify"
          }
        ]
      },
      {
        "matcher": "ask_user",
        "sequential": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/thinking_disciplines_pretool_hook.py",
            "name": "thinking-disciplines-pretool",
            "timeout": 10000,
            "description": "Reinforces thinking disciplines before ask_user"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "activate_skill|write_todos",
        "sequential": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/posttool_log_hook.py",
            "name": "posttool-log",
            "timeout": 10000,
            "description": "Reminds model to update execution log after milestones"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/stop_do_hook.py",
            "name": "stop-do",
            "timeout": 10000,
            "description": "Enforces /do workflow completion before stopping"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/prompt_submit_hook.py",
            "name": "prompt-submit-amendment",
            "timeout": 10000,
            "description": "Checks for manifest amendments on user input during /do"
          },
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/thinking_disciplines_prompt_hook.py",
            "name": "thinking-disciplines-prompt",
            "timeout": 10000,
            "description": "Reinforces thinking disciplines during active sessions"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/post_compact_hook.py",
            "name": "post-compact",
            "timeout": 10000,
            "description": "Restores workflow and thinking disciplines context after session resume/compact"
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${extensionPath}/hooks/post_compact_hook.py",
            "name": "pre-compress-recovery",
            "timeout": 10000,
            "description": "Restores workflow and thinking disciplines context after compaction"
          }
        ]
      }
    ]
  }
}
